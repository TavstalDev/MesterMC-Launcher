<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- UPDATE WINDOW -->
    
    <!-- #region Close Button Style -->
    <Style Selector="Button.CloseButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    
    <!-- Remove default button hover background -->
    <Style Selector="Button.CloseButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"></Setter>
    </Style>
    
    <!-- Apply normal image -->
    <Style Selector="Button.CloseButton > Image">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Source" Value="avares://MMC-Updater/Assets/buttons/close_normal.png" />
    </Style>

    <!-- Apply hover image -->
    <Style Selector="Button.CloseButton:pointerover > Image">
        <Setter Property="Source" Value="avares://MMC-Updater/Assets/buttons/close_over.png" />
    </Style>

    <!-- Apply pressed image -->
    <Style Selector="Button.CloseButton:pressed > Image">
        <Setter Property="Source" Value="avares://MMC-Updater/Assets/buttons/close_pressed.png" />
    </Style>
    <!-- #endregion Close Button Style -->
</Styles>
