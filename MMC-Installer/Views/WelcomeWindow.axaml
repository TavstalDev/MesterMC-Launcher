<Window
    x:Class="Tavstal.MesterMC.Installer.Views.WelcomeWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MesterMC Telepítő - Üdvözlő"
    Width="650"
    Height="400"
    d:DesignHeight="400"
    d:DesignWidth="650"
    Background="#F0F0F0"
    CanResize="False"
    Icon="avares://MMC-Installer/Assets/icons/favicon.png"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid RowDefinitions="*, Auto">
        
        <Grid Grid.Row="0" ColumnDefinitions="183, *">
            
            <Border Grid.Column="0" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,0">
                <Image Source="avares://MMC-Installer/Assets/images/banner.png" 
                       VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                       Margin="0"/> 
            </Border>

            <StackPanel Grid.Column="1" Margin="25" VerticalAlignment="Top">
                
                <TextBlock Text="Üdvözöl a MesterMC Indító telepítő varázsló"
                           FontSize="20" FontWeight="SemiBold"
                           Margin="0,0,0,25"
                           TextWrapping="Wrap"
                           Foreground="Black"/>

                <TextBlock Text="A MesterMC Indító telepítő varázsló segít a MesterMC Indító számítógépre történő telepítésében."
                           TextWrapping="Wrap"
                           Margin="0,0,0,5"
                           Foreground="Black"/>
                
                <TextBlock Text="Kattints a Tovább gombra a folytatáshoz, vagy a Mégse gombra a telepítő varázsló bezárásához."
                           TextWrapping="Wrap"
                           Margin="0,0,0,50"
                           Foreground="Black"/>

                <TextBlock Text="Copyright © 2025 MesterMC"
                           VerticalAlignment="Bottom"
                           Foreground="#666"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#CCCCCC" Padding="10" Background="#F0F0F0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Content="Tovább" 
                        Classes="DefaultBtn"
                        Width="80" 
                        Foreground="Black"
                />
                
                <Button Classes="DefaultBtn" Content="Mégse" Width="80"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
