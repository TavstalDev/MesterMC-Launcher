<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Tavstal.KonkordLauncher.Core</RootNamespace>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
	<Deterministic>false</Deterministic>
  </PropertyGroup>

  <PropertyGroup>
    <GenerateDebugInfo>false</GenerateDebugInfo>
    <PublishTrimmed>false</PublishTrimmed>
    <TrimMode>copyused</TrimMode>
    <TrimUnusedDependencies>true</TrimUnusedDependencies>
    <InvariantGlobalization>true</InvariantGlobalization>
    <EnableUnsafeUTF8Json>true</EnableUnsafeUTF8Json>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="DeviceId" Version="6.11.0" />
    <PackageReference Include="DeviceId.Linux" Version="6.11.0" />
    <PackageReference Include="DeviceId.Mac" Version="6.11.0" />
    <PackageReference Include="DeviceId.Windows" Version="6.11.0" />
    <PackageReference Include="DeviceId.Windows.Wmi" Version="6.11.0" />
    <PackageReference Include="Hardware.Info" Version="101.0.1.1" />
    <PackageReference Include="NbtLib" Version="1.0.1" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="SharpZipLib" Version="1.4.2" />
    <PackageReference Include="System.Security.Cryptography.ProtectedData" Version="9.0.8" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Assets\launchWrapper-1.0.jar" />
    <EmbeddedResource Include="Assets\launchWrapper-1.0.jar" />
  </ItemGroup>

</Project>
