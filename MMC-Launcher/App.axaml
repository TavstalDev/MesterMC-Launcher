<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Tavstal.MesterMC.Launcher.App"
             RequestedThemeVariant="Light">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

             <Application.Resources>
                 <ResourceDictionary>
                     <FontFamily x:Key="FontAwesome">Assets/fonts/fa-solid-900.ttf#Font Awesome 6 Free</FontFamily>
                 </ResourceDictionary>
             </Application.Resources>
    <Application.Styles>
        <FluentTheme />
        
        <!--  Controls  -->
        <StyleInclude Source="Styles/Buttons.axaml"  />
        <StyleInclude Source="Styles/Checkboxes.axaml" />
        <StyleInclude Source="Styles/Textboxes.axaml" />
        <StyleInclude Source="Styles/Comboboxes.axaml" />
        <StyleInclude Source="Styles/Settings.axaml" />
        
        <!--  Components  -->
        <StyleInclude Source="Styles/Components/NumericInput.axaml" />
    </Application.Styles>
</Application>