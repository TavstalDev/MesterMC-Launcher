<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Tavstal.MesterMC.Launcher.Views.Models"
        xmlns:models="clr-namespace:Tavstal.MesterMC.Launcher.Models"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="665"
        x:Class="Tavstal.MesterMC.Launcher.Views.LauncherWindow"
        x:DataType="vm:LauncherViewModel"
        Title="MMC Launcher"
        Width="1280"
        Height="665"
        CanResize="False"
        ShowInTaskbar="True"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="False"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        Icon="avares://MMC-Launcher/Assets/icons/favicon.png">
        <Window.Resources>
                <models:LoginStatusConverter x:Key="LoginConverter"/>
        </Window.Resources>
        <Grid>
                <!-- Background Image -->
                <Image Source="avares://MMC-Launcher/Assets/screens/mmc-launcher-bg.png" 
                       Stretch="Fill" 
                       VerticalAlignment="Stretch" 
                       HorizontalAlignment="Stretch"/>
                
                <!-- Logo -->
                <Image Source="{Binding LogoImage}" 
                       Height="120" 
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Margin="0,0,30,0"
                       />
                
                <!-- Character Image -->
                <Image Source="avares://MMC-Launcher/Assets/full.png" 
                       Height="250" 
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Margin="0,0,125,50"
                       Opacity="1"
                       />

                <!-- Close Button -->
                <Button Classes="ExitButton" Height="35"
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top"
                        Margin="0,30,10,0"
                        Background="Transparent"
                        Command="{Binding CloseWindowCommand}">
                        <Image />
                </Button>
                
                <!-- #region Left Side Panel -->
                <Grid  RowDefinitions="*, *, *, *"
                            HorizontalAlignment="Left" 
                            Height="574" 
                            Width="400"
                            RowSpacing="5"
                            Margin="0,-4.5,0,0"
                            Background="Transparent">
                        <!-- Facebook Button -->
                        <HyperlinkButton Grid.Row="0" Classes="FacebookButton" NavigateUri="https://www.facebook.com/mestermc.hu">
                                <Image />
                        </HyperlinkButton>
                        
                        <!-- Server List & Help Button -->
                        <Grid Grid.Row="1" ColumnDefinitions="*, *" ColumnSpacing="2">
                                <!-- ServerList Button -->
                                <HyperlinkButton Grid.Column="0" Classes="ServerListButton" NavigateUri="https://mestermc.hu/szerverek">
                                        <Image />
                                </HyperlinkButton> 
                                
                                <!-- Help Button -->
                                <HyperlinkButton Grid.Column="1" Classes="HelpButton" NavigateUri="mailto:info@mestermc.hu">
                                        <Image />
                                </HyperlinkButton> 
                        </Grid>
                        
                        <!-- Banyakozpont Button -->
                        <HyperlinkButton Grid.Row="2" Classes="BanyakozpontButton" NavigateUri="https://banyakozpont.mestermc.hu">
                                <Image />
                        </HyperlinkButton>
                        
                        <!-- Banyaszerme Button -->
                        <HyperlinkButton Grid.Row="3" Classes="BanyaszermeButton" NavigateUri="https://mestermc.hu/banyaszerme">
                                <Image />
                        </HyperlinkButton>
                </Grid>
                <!-- #endregion -->
                
                <!-- #region News Panel -->
                <Grid Height="571"
                      Margin="405,-4.5,315,0"
                      Background="Transparent">
                        <!-- News Title -->
                        <StackPanel Margin="25,40,0,0" Orientation="Horizontal">
                                <TextBlock Foreground="#ffff00" 
                                        FontSize="36" 
                                        FontWeight="300"
                                        Text="FRISS" />
                                <TextBlock Foreground="White" 
                                           FontSize="36" 
                                           FontWeight="600"
                                           Text=" HÍREINK" />
                        </StackPanel>
                        
                        <!-- Pages -->
                        <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="Auto, Auto" RowSpacing="5" ColumnSpacing="10" HorizontalAlignment="Right" Margin="0, -15, 25, 0">
                                <!-- PrevPage Button -->
                                <Button Grid.Row="0" Grid.Column="0" Classes="PrevPageButton" Height="35"
                                        HorizontalAlignment="Right" 
                                        VerticalAlignment="Top"
                                        Background="Transparent"
                                        Command="{Binding PreviousNewsCommand}">
                                        <Image />
                                </Button>
                                <!-- NextPage Button -->
                                <Button Grid.Row="0" Grid.Column="1" Classes="NextPageButton" Height="35"
                                        HorizontalAlignment="Right" 
                                        VerticalAlignment="Top"
                                        Background="Transparent"
                                        Command="{Binding NextNewsCommand}">
                                        <Image />
                                </Button>
                                <!-- Page Text -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                                           Foreground="#727170" 
                                           FontWeight="600"
                                           HorizontalAlignment="Center"
                                           Text="{Binding NewsPageDisplay}" />
                        </Grid>
                        
                        <!-- News Content -->
                        <Grid RowDefinitions="Auto, Auto, *"
                                    Margin="25,115,25,50"
                                    VerticalAlignment="Top"
                                    Height="400"
                                    RowSpacing="8"
                                    >
                                <!-- Content Title -->
                                <TextBlock Foreground="#ffb400" FontWeight="600" Text="{Binding SelectedNewsItem.Title}" />
                        
                                <!-- Content Banner -->
                                <Image Grid.Row="1" Source="{Binding SelectedNewsItem.Banner}" />
                        
                                <!-- Content Text -->
                                <TextBlock Grid.Row="2" FontWeight="300" Foreground="White" TextWrapping="Wrap" Text="{Binding SelectedNewsItem.Content}" />
                        </Grid>
                        
                </Grid>
                <!-- #endregion -->
                
                <!-- #region Login Panel -->
                <Grid Height="350"
                      Width="285"
                      HorizontalAlignment="Right"
                      Margin="0,-4.5,29,0"
                      Background="Transparent"
                      RowDefinitions="Auto, Auto, Auto, Auto"
                      RowSpacing="8"
                      IsVisible="{Binding !isLoggingIn}">
                        
                        <!-- Username TextBox -->
                        <TextBox Grid.Row="0" Height="30"
                                 Classes="LoginBox"
                                 Width="230"
                                 Margin="0"
                                 VerticalAlignment="Top"
                                 VerticalContentAlignment="Center"
                                 Watermark="Felhasználónév"
                                 CornerRadius="4"
                                 Text="{Binding Username}"/>
                        
                        <!-- Password TextBox -->
                        <TextBox Grid.Row="1" Height="30"
                                 Classes="LoginBox"
                                 Width="230"
                                 Margin="0"
                                 VerticalAlignment="Top"
                                 VerticalContentAlignment="Center"
                                 Watermark="Jelszó"
                                 CornerRadius="4"
                                 Text="{Binding Password}"
                                 IsEnabled="{Binding !OfflineMode}"/>
                        
                        <!-- Offline Login CheckBox -->
                        <CheckBox Grid.Row="2"
                                  Classes="OfflineCheckBox"
                                  Foreground="White"
                                  FontSize="18"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  Margin="30, 0, 30, 0"
                                  Padding="0"
                                  IsChecked="{Binding OfflineMode, Mode=TwoWay}"
                                  IsEnabled="False">
                               <Border Width="205">
                                       <TextBlock Text="Offline mód" />
                               </Border>
                        </CheckBox>
                        
                        <!-- Login Button -->
                        <Button Grid.Row="3" 
                                Classes="LoginButton"
                                Height="72"
                                Margin="0, 5,0,0"
                                Command="{Binding LoginCommand}">
                                <Image />
                        </Button>
                </Grid>
                <!-- #endregion -->
                
                <!-- #region Auth Feedback -->
                <Grid Height="350"
                      Width="285"
                      HorizontalAlignment="Right"
                      Margin="0,-4.5,29,0"
                      Background="Transparent"
                      RowDefinitions="Auto"
                      RowSpacing="8"
                      IsVisible="{Binding isLoggingIn}">
                        
                        <Image Source="{Binding LoginStatus, Converter={StaticResource LoginConverter}}"/>
                </Grid>
                <!-- #endregion -->
        </Grid>
</Window>
