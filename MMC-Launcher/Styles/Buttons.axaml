        <Setter Property="Source" Value="avares://MMC-Launcher/Assets/buttons/back-btn-active.png" />
    </Style>
    <!-- #endregion ErrorBack Button Style -->
    
    <!-- #region Category Button Style -->
    <Style Selector="Button.CategoryButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Margin" Value="20, 0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    
    <Style Selector="Button.CategoryButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    
    <!-- Apply normal image -->
    <Style Selector="Button.CategoryButton > Grid > Image">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Stretch" Value="Fill" />
        <Setter Property="Source" Value="avares://MMC-Launcher/Assets/buttons/blank-btn-normal.png" />
    </Style>

    <!-- Apply hover image -->
    <Style Selector="Button.CategoryButton:pointerover > Grid > Image">
        <Setter Property="Source" Value="avares://MMC-Launcher/Assets/buttons/blank-btn-hover.png" />
    </Style>

    <!-- Apply pressed image -->
    <Style Selector="Button.CategoryButton:pressed > Grid > Image">
        <Setter Property="Source" Value="avares://MMC-Launcher/Assets/buttons/blank-btn-active.png" />
    </Style>
    
    <Style Selector="TextBlock.CategoryButton">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="600" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Effect">
            <DropShadowEffect Color="Black" OffsetX="1" OffsetY="1" BlurRadius="6" Opacity="0.85"/>
        </Setter>
    </Style>
    <!-- #endregion Category Button Style -->
</Styles>
