    </Style>
    
    <!-- Apply normal image -->
    <Style Selector="Button.ErrorBackButton > Image">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Source" Value="avares://MMC-Launcher/Assets/buttons/back-btn-normal.png" />
    </Style>

    <!-- Apply hover image -->
