<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="WrapPanel.SettingsWrapper">
        <Setter Property="LineSpacing" Value="10" />
        <Setter Property="ItemSpacing" Value="10" />
        <Setter Property="Width" Value="440"></Setter>
        <Setter Property="ItemWidth" Value="440" />
        <Setter Property="Margin" Value="0,10,0,25" />
        <Setter Property="Orientation" Value="Vertical" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    
    <Style Selector="TextBlock.SettingsCategory">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,10" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="White" />
    </Style>
</Styles>
