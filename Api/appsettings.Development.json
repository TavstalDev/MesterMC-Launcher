{
  "// ============ INFRASTRUCTURE ============": "",
  "Kestrel": {
    "Endpoints": {
      "Https": {
        "Url": "https://localhost:36767",
        "Certificate": {
          "Path": "localhost.pfx",
          "Password": "changeit"
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",

  "// ============ SECURITY & AUTHENTICATION ============": "",
  "Jwt": {
    "Issuer": "https://localhost:36767",
    "Audience": "https://localhost:36767",
    "ClockSkew": 5,
    "Lockout": {
      "MaxAttempts": 5,
      "Duration": 900
    }
  },
  "Database": {
    "_comment": "Supported providers: MySql, Sqlite, PostgreSql. It will defaults to MySql if wrongly specified.",
    "Provider": "MySql",
    "Version": "8.0.31",
    "ConnectionString": "server=127.0.0.1;port=3306;database=mmc;uid=$DB_USER;pwd=$DB_PASSWORD;"
  },

  "// ============ API FEATURES ============": "",
  "CORS": {
    "Default": {
      "AllowAnyOrigin": true,
      "AllowAnyHeader": true,
      "AllowAnyMethod": true,
      "MaxAge": 3600,
      "Sites": [
        "https://localhost:36767",
        "https://localhost:36766"
      ],
      "Headers": [],
      "Methods": []
    }
  },
  "RateLimiting": {
    "_comment": "Don't forge to modify RateLimits class to reflect the changes here.",
    "StatusCode": 429,
    "UploadLimitMegabytes": 100,
    "Rules": {
      "Default": {
        "PermitLimit": 100,
        "WindowSeconds": 60,
        "QueueLimit": 10
      },
      "AuthRegister": {
        "PermitLimit": 2,
        "WindowSeconds": 3600,
        "QueueLimit": 10
      },
      "AuthLogin": {
        "PermitLimit": 5,
        "WindowSeconds": 300,
        "QueueLimit": 5
      },
      "AuthReset": {
        "PermitLimit": 3,
        "WindowSeconds": 3600,
        "QueueLimit": 5
      },
      "Upload": {
        "PermitLimit": 20,
        "WindowSeconds": 600,
        "QueueLimit": 5
      },
      "Download": {
        "PermitLimit": 30,
        "WindowSeconds": 300,
        "QueueLimit": 5
      },
      "Search": {
        "PermitLimit": 60,
        "WindowSeconds": 60,
        "QueueLimit": 5
      },
      "Write": {
        "PermitLimit": 30,
        "WindowSeconds": 60,
        "QueueLimit": 5
      },
      "Admin": {
        "PermitLimit": 20,
        "WindowSeconds": 60,
        "QueueLimit": 5
      }
    }
  },

  "// ============ EXTERNAL SERVICES ============": "",
  "Email": {
    "Provider": "localhost",
    "Port": 1025
  },
  "Discord": {
    "GuildId": "000000000000000000",
    "RedirectUri": "https://localhost:36766/oauth/callback?provider=discord"
  },

  "// ============ GAME SERVER CONFIGURATION ============": "",
  "Yggdrasil": {
    "SkinDomains": [
      "localhost"
    ],
    "ServerName": "MesterMC Development",
    "ImplementationName": "yggdrasil-mock-server",
    "ImplementationVersion": "1.0.0"
  },

  "// ============ RUNTIME PATHS ============": "",
  "Runtime": {
    "UploadDir": "wwwroot/uploads",
    "WebsiteUrl": "https://localhost:36766",
    "ApiUrl": "https://localhost:36767"
  }
}
