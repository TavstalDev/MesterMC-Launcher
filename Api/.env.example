# Copy this file to Api/.env and set secure values locally. DO NOT commit your real secrets.
# Use a secure random string for JWT_ENCRYPTION_KEY (at least 32 bytes recommended).
JWT_ENCRYPTION_KEY=replace_with_secure_random_value

# Database credentials
DB_USER=replace_db_user
DB_PASSWORD=replace_db_password

# Email credentials used for sending mails (development values okay for local testing)
EMAIL_ADDRESS=example@example.com
EMAIL_PASSWORD=replace_email_password

# SSL Certificate Password (default for development certificate: changeit)
CERT_PASSWORD=changeit
